{
  "name": "macpack",
  "version": "0.1.0",
  "description": "Universal macOS package manager CLI for Homebrew, npm, bun, and uv manifests.",
  "type": "module",
  "bin": {
    "macpack": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run src",
    "prepack": "npm run build"
  },
  "keywords": [
    "macos",
    "homebrew",
    "brew",
    "npm",
    "bun",
    "uv",
    "cli",
    "package-manager"
  ],
  "author": "sk2andy",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "volta": {
    "node": "22.22.1"
  }
}

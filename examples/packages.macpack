# Package manifest for ~/.config/binst/binst.sh.
#
# Homebrew entries are filtered into ~/.config/binst/Brewfile.
# Other entries are installed/updated by their matching manager.
#
# Supported:
#   tap "owner/repo"
#   brew "formula"
#   cask "app"
#   mas "App Name" "123456789"
#   npm "package"
#   pnpm "package"
#   bun "package"
#   uv "python-version" "package"
#   repo "git-url" "target-directory"

tap "azure/functions"
tap "danielfoehrkn/switch"
tap "isen-ng/dotnet-sdk-versions"
tap "nikolaeu/numi"
tap "cocoanetics/tap"
tap "anomalyco/tap"

brew "act"
brew "azure-cli"
brew "azure-functions-core-tools@4"
brew "bat"
brew "bitwarden-cli"
